# ============================================================
# 岚图汽车 · 洞察信息收集日报 · 配置文件
# ============================================================

# DeepSeek API 配置
llm:
  api_key: "YOUR_DEEPSEEK_API_KEY"
  base_url: "https://api.deepseek.com/v1"
  model: "deepseek-chat"
  temperature: 0.3
  max_tokens: 2000
  # 请求超时（秒）
  timeout: 60
  # 请求间隔（秒），防止限流
  request_interval: 1

# 数据源配置
sources:
  # ============================================================
  # 数据源配置（按渠道分类）
  # 策略：垂直媒体优先 + 综合门户覆盖 + 财经RSS补充
  # ============================================================

  # --- RSS源（财经/科技门户）---
  rss:
    - name: "36氪"
      url: "https://36kr.com/feed"
      enabled: true
      rss_keyword_filter: ["新能源", "电动", "车企", "比亚迪", "特斯拉", "蔚来", "理想", "小鹏", "问界", "岚图", "极氪", "腾势", "智驾", "电池", "充电", "交付", "销量", "汽车", "混动", "增程", "自动驾驶", "固态电池"]
    - name: "IT之家"
      url: "https://www.ithome.com/rss/"
      enabled: true
      rss_keyword_filter: ["新能源", "电动", "车企", "比亚迪", "特斯拉", "蔚来", "理想", "小鹏", "问界", "岚图", "极氪", "腾势", "智驾", "电池", "充电", "交付", "销量", "汽车", "混动", "增程", "自动驾驶", "固态电池", "e-tron"]

  # --- 汽车垂直行业媒体（最相关，优先抓取）---
  web:
    - name: "盖世汽车"
      url: "https://auto.gasgoo.com/"
      enabled: true
      list_selector: ".lastNews a"
      title_selector: "h1"
      content_selector: ".detailed"
    - name: "第一电动网"
      url: "https://www.d1ev.com/news"
      enabled: true
      list_selector: ".news-list li a, .left-list li a"
      title_selector: "h1"
      content_selector: ".ws-newscon, .ws-md"
    - name: "OFweek新能源汽车"
      url: "https://nev.ofweek.com/"
      enabled: true
      list_selector: ".news-list a, .list-item a"
      title_selector: "h1"
      content_selector: ".article-content, .content"
    - name: "电车之家"
      url: "https://www.zhev.com.cn/"
      enabled: false
      list_selector: ".list-item a, .news-list a"
      title_selector: "h1"
      content_selector: ".left_box, .m_l"

  # --- 综合门户汽车频道（内容量大，需关键词过滤）---
  portal:
    - name: "汽车之家"
      url: "https://www.autohome.com.cn/news/"
      enabled: true
      list_selector: ".list-cont li a"
      title_selector: "h1"
      content_selector: ".article-content"
    - name: "网易汽车"
      url: "https://auto.163.com/"
      enabled: true
      list_selector: ".news_list li a"
      title_selector: "h1"
      content_selector: ".post_body"
    - name: "新浪汽车"
      url: "https://auto.sina.com.cn/news/"
      enabled: true
      list_selector: ".list-item a"
      title_selector: "h1"
      content_selector: ".article"
    - name: "搜狐汽车"
      url: "https://auto.sohu.com/"
      enabled: true
      list_selector: ".news-list a"
      title_selector: "h1"
      content_selector: ".article"

  # --- 政府/协会官网（对应国家/政策层）---
  government:
    - name: "工信部"
      url: "https://www.miit.gov.cn/xwdt/gxdt/sjdt/index.html"
      enabled: true
      list_selector: ".list-item li a"
      title_selector: "h1"
      content_selector: ".article-content"

  # --- 能源/储能/光伏媒体（补充国家/政策层 + 技术/研发层）---
  energy:
    - name: "中国储能网"
      url: "https://www.escn.com.cn/"
      enabled: true
      list_selector: "a[href*='/news/show-']"
      title_selector: "h1"
      content_selector: ".entry"
    - name: "北极星储能网"
      url: "https://chuneng.bjx.com.cn/"
      enabled: true
      list_selector: "a[href*='/news/']"
      title_selector: "h1"
      content_selector: ".js-detail-center"
    - name: "国际能源网"
      url: "https://www.in-en.com/"
      enabled: true
      list_selector: "a[href*='/article/']"
      title_selector: "h1"
      content_selector: ".content.fix"
    - name: "每日光伏新闻"
      url: "https://news.solarbe.com/"
      enabled: true
      list_selector: "a[href*='/2026']"
      title_selector: "h1"
      content_selector: "#content"
    - name: "央视网-汽车"
      url: "https://auto.cctv.com/"
      enabled: true
      list_selector: "a[href*='VIDE']"
      title_selector: "h1"
      content_selector: ".page_wrap"
    - name: "北极星电力网"
      url: "https://www.bjx.com.cn/"
      enabled: true
      list_selector: "a[href*='/html/']"
      title_selector: "h1"
      content_selector: ".cc-layout-3"

  # 手动输入源（用户粘贴URL，运行时通过 --urls 参数传入）
  manual_urls: []

# 抓取配置
fetch:
  # 抓取时间范围（小时），默认前24小时
  hours_range: 96
  # 每个源最大抓取文章数
  max_articles_per_source: 20
  # 请求超时（秒）
  timeout: 30
  # 请求间隔（秒）
  request_interval: 2
  # User-Agent
  user_agent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
  # 代理配置（可选）
  proxy: null

# 关键词配置（也可在 keywords.json 中编辑）
keywords:
  # 必收关键词 - 命中任一则保留
  must_include_file: "config/keywords.json"
  # 排除关键词 - 命中任一则过滤
  exclude_file: "config/keywords.json"

# 层面分类规则
# 注意：涉及具体公司/品牌的新闻优先归入业务/竞争层（代码中硬编码判断）
category_rules:
  "国家/政策层":
    keywords: ["发改委", "工信部", "国务院", "商务部", "财政部", "补贴", "关税", "双积分", "碳达峰", "碳中和", "标准", "规划", "政策", "法规", "条例", "管理办法", "征求意见", "通知", "公告", "管理办法", "回收利用", "溯源", "安全标准"]
  "行业/市场层":
    keywords: ["市场份额", "渗透率", "价格战", "行业报告", "行业分析", "行业趋势", "市场预测", "消费者", "出海趋势", "全球化", "进口", "出口数据", "充电桩", "充电网络", "基础设施", "行业寒冬", "市场承压"]
  "技术/研发层":
    keywords: ["电池", "电驱", "电控", "智能驾驶", "座舱", "芯片", "操作系统", "热效率", "固态电池", "半固态", "钠离子", "钠电池", "大模型", "激光雷达", "800V", "快充", "换电", "CTP", "CTC", "一体化压铸", "混动发动机", "超高压", "超充", "闪充", "ai技术", "fsd", "自动驾驶技术", "智能座舱", "主动安全", "储能电池", "储能系统", "储能电站", "光伏组件", "光伏电池", "钙钛矿", "锂电", "磷酸铁锂", "三元锂", "刀片电池", "固态电池", "电池回收", "电池材料", "充电桩", "充电站", "充电网络", "动力电池", "电芯", "电池包", "电池管理系统", "BMS", "储能", "光伏", "逆变器", "PCS", "EMS", "飞轮储能", "压缩空气储能", "液流电池", "全固态"]
  "业务/竞争层":
    keywords: ["新车", "发布", "上市", "预售", "产能", "工厂", "人事", "战略合作", "融资", "收购", "合并", "裁员", "召回", "维权", "投诉", "经销商", "渠道", "交付", "销量", "大定", "订单", "代理", "经销商", "破产", "更名", "转型"]

# 输出配置
output:
  # 输出目录
  daily_dir: "output/daily"
  biweekly_dir: "output/biweekly"
  archive_dir: "output/archive"
  # 日报文件名模板
  daily_filename: "洞察信息收集日报_{date}.docx"
  # Markdown文件名模板
  daily_md_filename: "洞察信息收集日报_{date}.md"
  # 半月报文件名模板
  biweekly_filename: "洞察信息半月报_{start}_{end}.docx"
  biweekly_md_filename: "洞察信息半月报_{start}_{end}.md"
  # 日期格式
  date_format: "%Y%m%d"

# 定时调度
schedule:
  # 每日执行时间（HH:MM）
  daily_time: "07:00"
  # 半月报生成时间（每月1号和16号）
  biweekly_days: [1, 16]

# 通知配置（可选）
notification:
  # 企业微信Webhook（可选）
  wecom_webhook: null
  # 邮件通知（可选）
  email:
    enabled: false
    smtp_server: ""
    smtp_port: 465
    sender: ""
    password: ""
    receivers: []

# 日志配置
logging:
  level: "INFO"
  file: "logs/app.log"
  max_size: "10MB"
  backup_count: 5
